generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String?
  provider     String        @default("email")
  role         Role          @default(STUDENT)
  createdAt    DateTime      @default(now())
  profile      Profile?
  applications Application[]
  savedRoles   SavedRole[]
  aiSessions   AISession[]
}

enum Role {
  STUDENT
  ADMIN
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  fullName    String?
  college     String?
  degree      String?
  gradYear    Int?
  resumeUrl   String?
  bio         String?
  skills      Skill[]
  preferences Json?
  updatedAt   DateTime @updatedAt
}

model Skill {
  id        String  @id @default(cuid())
  name      String
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id])
}

model Company {
  id          String       @id @default(cuid())
  name        String
  logoUrl     String?
  website     String?
  industry    String?
  description String?
  internships Internship[]
}

model Internship {
  id           String        @id @default(cuid())
  title        String
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  description  String
  requirements String[]
  skills       String[]
  location     String
  isRemote     Boolean       @default(false)
  stipend      Int?
  duration     String?
  applyUrl     String?
  deadline     DateTime?
  domain       String?
  isActive     Boolean       @default(true)
  type         String        @default("Job")
  country      String?       @default("India")
  postedAt     DateTime      @default(now())
  applications Application[]
  savedBy      SavedRole[]
}

model Application {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  internshipId String
  internship   Internship @relation(fields: [internshipId], references: [id])
  status       AppStatus  @default(SAVED)
  notes        String?
  coverLetter  String?
  appliedAt    DateTime?
  updatedAt    DateTime   @updatedAt

  @@unique([userId, internshipId])
}

enum AppStatus {
  SAVED
  APPLIED
  INTERVIEW
  OFFER
  REJECTED
}

model SavedRole {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  internshipId String
  internship   Internship @relation(fields: [internshipId], references: [id])
  savedAt      DateTime   @default(now())

  @@unique([userId, internshipId])
}

model AISession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  input     Json
  output    Json
  tokens    Int?
  createdAt DateTime @default(now())
}